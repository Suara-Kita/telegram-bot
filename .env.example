# ─────────────────────────────────────────────
# Telegram Bot
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ─────────────────────────────────────────────
# Redis (point to host when running locally)
# ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=redis

# ─────────────────────────────────────────────
# Queues
# ─────────────────────────────────────────────
QUEUE_VOTER_INPUTS=queue:voter_inputs

# ─────────────────────────────────────────────
# LLM (OpenRouter)
# ─────────────────────────────────────────────
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
LLM_MODEL=openai/gpt-oss-120b

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
LOG_LEVEL=info
