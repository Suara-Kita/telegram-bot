{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VoterInput",
  "description": "Unified ingestion payload pushed to queue:voter_inputs by any ingestion engine",
  "type": "object",
  "required": [
    "pipeline_metadata",
    "source_profile",
    "content_payload"
  ],
  "properties": {
    "pipeline_metadata": {
      "type": "object",
      "description": "System-level tracing and telemetry",
      "required": ["ingestion_id", "source_channel", "ingested_at"],
      "properties": {
        "ingestion_id": {
          "type": "string",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
          "description": "UUIDv4 generated by the ingestion engine at the moment of receipt"
        },
        "source_channel": {
          "type": "string",
          "enum": ["whatsapp", "telegram", "facebook_crawler", "news_crawler", "web_portal", "f2f_staff"],
          "description": "Origin channel of the message"
        },
        "ingested_at": {
          "type": "string",
          "format": "date-time",
          "description": "UTC ISO 8601 timestamp of ingestion"
        },
        "trace_url": {
          "type": ["string", "null"],
          "format": "uri",
          "description": "Direct URL to source post/thread (null for private 1-to-1 chats)"
        },
        "retry_count": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Number of times this message has been retried from the DLQ"
        }
      }
    },
    "source_profile": {
      "type": "object",
      "description": "Sender identity or platform footprint",
      "required": ["client_identifier"],
      "properties": {
        "client_identifier": {
          "type": "string",
          "description": "Platform-specific unique ID (phone number, chat ID, user hash)"
        },
        "display_name": {
          "type": ["string", "null"],
          "description": "Public profile name or nickname"
        },
        "contact_info": {
          "type": ["string", "null"],
          "description": "Secondary contact (phone, email) if explicitly provided"
        },
        "inferred_constituency": {
          "type": ["string", "null"],
          "description": "Geographical/constituency hint (e.g. P.102 Bangi)"
        }
      }
    },
    "content_payload": {
      "type": "object",
      "description": "Core raw message content",
      "required": ["raw_text", "media_attachments", "content_type"],
      "properties": {
        "raw_text": {
          "type": "string",
          "description": "Unedited raw input — may contain slang, typos, dialect"
        },
        "content_type": {
          "type": "string",
          "enum": ["text_only", "image", "video", "document", "audio"],
          "description": "Primary content type of the message"
        },
        "media_attachments": {
          "type": "array",
          "items": { "type": "string", "format": "uri" },
          "description": "URLs to object storage (empty array if none)"
        }
      }
    },
    "context_anchor": {
      "oneOf": [
        {
          "type": "null",
          "description": "Direct 1-to-1 chat with no parent context"
        },
        {
          "type": "object",
          "description": "Semantic link to parent thread or post",
          "required": ["is_reply_or_comment", "parent_id", "parent_title", "parent_raw_text"],
          "properties": {
            "is_reply_or_comment": {
              "type": "boolean"
            },
            "parent_id": {
              "type": "string",
              "description": "Platform ID of the root post/thread"
            },
            "parent_title": {
              "type": "string",
              "description": "Headline or title of the parent"
            },
            "parent_raw_text": {
              "type": "string",
              "description": "Full original text of the parent post"
            }
          }
        }
      ]
    }
  }
}
